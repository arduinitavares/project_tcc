OPEN_ROUTER_API_KEY=your_openrouter_key

# Required business database configuration
AGILEFORGE_DB_URL=sqlite:///./db/spec_authority_dev.db

# Required ADK/session database configuration
AGILEFORGE_SESSION_DB_URL=sqlite:///./db/spec_authority_session_dev.db

# Optional runtime settings
AGILEFORGE_DB_ECHO=false
AGILEFORGE_API_HOST=0.0.0.0
AGILEFORGE_API_PORT=8000
AGILEFORGE_API_RELOAD=true
