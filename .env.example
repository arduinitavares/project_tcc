OPEN_ROUTER_API_KEY=your_openrouter_key

# Required business database configuration
PROJECT_TCC_DB_URL=sqlite:///./db/spec_authority_dev.db

# Required ADK/session database configuration
PROJECT_TCC_SESSION_DB_URL=sqlite:///./db/spec_authority_session_dev.db

# Optional runtime settings
PROJECT_TCC_DB_ECHO=false
PROJECT_TCC_API_HOST=0.0.0.0
PROJECT_TCC_API_PORT=8000
PROJECT_TCC_API_RELOAD=true
